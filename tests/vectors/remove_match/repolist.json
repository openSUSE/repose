    ],
    "expected": []
  },
  {
    "name": "multiple_patterns_union",
    "patterns": [
      "SLES:15-SP4::repo1",
      "SLES:15-SP4::repo2"
    ],
    "aliases": [
      "SLES:15-SP4::repo1",
      "SLES:15-SP4::repo2",
      "SLES:15-SP4::repo3"
    ],
    "expected": [
