      "SLES:15-SP4::"
    ],
    "aliases": [
      "SLES:15-SP4::repo1",
      "SLES:15-SP4::repo10",
      "other:repo"
    ],
    "expected": [
      "SLES:15-SP4::repo1",
      "SLES:15-SP4::repo10"
    ]
  },
  {
    "name": "double_colon_no_match",
