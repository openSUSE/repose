  <repositories>
      <repository type="update" repoid="obsrepository://example.invalid/scrubbed" />
      <repository type="update" repoid="obsrepository://example.invalid/scrubbed" />
      <repository type="pool" repoid="obsproduct://example.invalid/SUSE:Products:SLE-Module-Live-Patching:15-SP5:x86_64/sle-module-live-patching/15.5/x86_64" />
