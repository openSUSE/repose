  </register>
  <repositories>
      <repository type="update" repoid="obsrepository://example.invalid/scrubbed" />
      <repository type="update" repoid="obsrepository://example.invalid/scrubbed" />
      <repository type="pool" repoid="obsproduct://example.invalid/scrubbed" />
